// ifè FOOD — Prisma Schema v1.0
// PostgreSQL Database Schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  //url = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────

enum UserRole {
  CLIENT
  PROFESSIONAL
  DRIVER
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BANNED
}

enum AdminLevel {
  SUPER_ADMIN
  ADMIN
  SUPPORT
  MODERATOR
  ANALYST
}

model Country {
  code     String  @id
  name     String
  emoji    String?
  currency String  @default("XOF")
  isActive Boolean @default(true)

  @@map("countries")
}

enum ProfessionalCategory {
  RESTAURANT
  GROCERY
  SUPERMARKET
  BAKERY
  PHARMACY
  OTHER
}

enum ProfessionalStatus {
  PENDING
  VALIDATED
  REJECTED
  SUSPENDED
  BANNED
}

enum DriverStatus {
  PENDING
  VALIDATED
  REJECTED
  ONLINE
  OFFLINE
  SUSPENDED
  BANNED
}

enum VehicleType {
  BICYCLE
  MOTORCYCLE
  CAR
  ON_FOOT
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  ACCEPTED
  REJECTED
  IN_PREPARATION
  READY_FOR_PICKUP
  DRIVER_ASSIGNED
  PICKED_UP
  IN_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentGateway {
  STRIPE
  PAYPAL
  KKIAPAY
  FEDAPAY
  CASH_ON_DELIVERY
  OTHER
}

enum DeliveryStatus {
  ASSIGNED
  HEADING_TO_PICKUP
  ARRIVED_AT_PICKUP
  PICKED_UP
  IN_DELIVERY
  DELIVERED
  FAILED
}

enum TransactionType {
  COMMISSION
  PAYOUT
  REFUND
  DELIVERY_FEE
  TIP
}

enum WalletTxType {
  REFERRAL_REWARD
  ADMIN_CREDIT
  ADMIN_DEBIT
}

enum ReferralStatus {
  PENDING
  REWARDED
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum NotificationType {
  ORDER_NEW
  ORDER_ACCEPTED
  ORDER_IN_PREPARATION
  ORDER_READY
  ORDER_DRIVER_ASSIGNED
  ORDER_IN_DELIVERY
  ORDER_DELIVERED
  ORDER_CANCELLED
  MISSION_NEW
  PAYOUT_SENT
  ACCOUNT_VALIDATED
  ACCOUNT_REJECTED
  PROMO
  SYSTEM
}

enum NotificationChannel {
  PUSH
  SMS
  WHATSAPP
  EMAIL
}

enum OtpChannel {
  SMS
  WHATSAPP
}

enum Language {
  fr
  en
  es
  de
  ru
  ar
  zh
}

// ─── USERS ────────────────────────────────────

model User {
  id               String     @id @default(uuid())
  phone            String     @unique
  phoneCountry     String
  name             String?
  firstName        String?
  email            String?    @unique
  avatarUrl        String?
  role             UserRole
  status           UserStatus @default(PENDING)
  lang             Language   @default(en)
  countryCode      String     @default("BJ")
  currency         String     @default("XOF")
  pinHash          String?
  biometricEnabled Boolean    @default(false)
  fcmToken         String?
  twoFaSecret      String?
  twoFaEnabled     Boolean    @default(false)
  lastLoginAt      DateTime?
  lastLoginIp      String?
  createdByAdmin   Boolean    @default(false)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  deletedAt        DateTime?

  professional     Professional?
  driver           Driver?
  admin            Admin?
  clientOrders     Order[]        @relation("ClientOrders")
  reviews          Review[]
  notifications    Notification[]
  messages         Message[]
  otpSessions      OtpSession[]
  loginLogs        LoginLog[]
  legalAcceptances LegalAcceptance[]
  addresses        UserAddress[]
  referralCode     String?           @unique
  wallet           Wallet?
  referrals        Referral[]        @relation("ReferrerReferrals")
  referredAs       Referral?         @relation("RefereeReferral")

  @@map("users")
}

// Adresses sauvegardées d'un user (livraison côté CLIENT).
// `isDefault` : une seule adresse par user peut être true à la fois — géré
// côté service (transaction qui désactive les autres lors d'un set).
model UserAddress {
  id          String   @id @default(uuid())
  userId      String
  label       String   // ex: "Maison", "Bureau", "Chez Maman"
  address     String   // ligne d'adresse complète
  city        String
  country     String   @default("BJ")
  lat         Float?
  lng         Float?
  isDefault   Boolean  @default(false)
  instructions String? // "Sonner 2x", "Code 1234", etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isDefault])
  @@map("user_addresses")
}

model OtpSession {
  id        String     @id @default(uuid())
  userId    String?
  phone     String
  code      String
  channel   OtpChannel
  attempts  Int        @default(0)
  verified  Boolean    @default(false)
  expiresAt DateTime
  createdAt DateTime   @default(now())
  user      User?      @relation(fields: [userId], references: [id])

  @@map("otp_sessions")
}

model LoginLog {
  id        String   @id @default(uuid())
  userId    String
  ip        String
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@map("login_logs")
}

model LegalAcceptance {
  id           String   @id @default(uuid())
  userId       String
  documentType String
  version      String
  acceptedAt   DateTime @default(now())
  ip           String?
  user         User     @relation(fields: [userId], references: [id])

  @@map("legal_acceptances")
}

// ─── PROFESSIONALS ────────────────────────────

model Professional {
  id                 String              @id @default(uuid())
  userId             String              @unique
  businessName       String
  category           ProfessionalCategory
  description        String?
  address            String
  city               String
  country            String
  lat                Float
  lng                Float
  coverImageUrl      String?
  logoUrl            String?
  phone              String?
  email              String?
  website            String?
  rccm               String?
  status             ProfessionalStatus  @default(PENDING)
  commissionRate     Float?
  deliveryRadiusKm   Float               @default(10)
  isOpen             Boolean             @default(false)
  openingHours       Json?
  adminNote          String?
  validatedAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  user               User                @relation(fields: [userId], references: [id])
  products           Product[]
  productCategories  ProductCategory[]
  orders             Order[]             @relation("ProfessionalOrders")
  documents          Document[]
  reviews            Review[]
  favoriteDrivers    ProfessionalFavoriteDriver[]
  transactions       Transaction[]
  promoCodes         PromoCode[]

  @@map("professionals")
}

model ProfessionalFavoriteDriver {
  professionalId String
  driverId       String
  createdAt      DateTime     @default(now())
  professional   Professional @relation(fields: [professionalId], references: [id])
  driver         Driver       @relation(fields: [driverId], references: [id])

  @@id([professionalId, driverId])
  @@map("professional_favorite_drivers")
}

// ─── DRIVERS ──────────────────────────────────

model Driver {
  id               String       @id @default(uuid())
  userId           String       @unique
  vehicleType      VehicleType
  licensePlate     String?
  driverLicenseUrl String?
  status           DriverStatus @default(PENDING)
  currentLat       Float?
  currentLng       Float?
  zoneCity         String?
  zoneCountry      String?
  zoneRadiusKm     Float        @default(10)
  isAvailable              Boolean      @default(false)
  isPrivate                Boolean      @default(false)
  privateForProfessionalId String?
  adminNote        String?
  validatedAt      DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user             User         @relation(fields: [userId], references: [id])
  deliveries       Delivery[]
  documents        Document[]
  reviews          Review[]
  transactions     Transaction[]
  favoritedBy      ProfessionalFavoriteDriver[]
  orders           Order[]

  @@map("drivers")
}

// ─── ADMINS ───────────────────────────────────

model Admin {
  id        String     @id @default(uuid())
  userId    String     @unique
  level     AdminLevel @default(ADMIN)
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id])

  @@map("admins")
}

// ─── DOCUMENTS ────────────────────────────────

model Document {
  id             String        @id @default(uuid())
  professionalId String?
  driverId       String?
  type           String
  url            String
  verified       Boolean       @default(false)
  createdAt      DateTime      @default(now())
  professional   Professional? @relation(fields: [professionalId], references: [id])
  driver         Driver?       @relation(fields: [driverId], references: [id])

  @@index([professionalId])
  @@index([driverId])
  @@map("documents")
}

// ─── PRODUCTS ─────────────────────────────────

model ProductCategory {
  id             String    @id @default(uuid())
  professionalId String
  name           Json
  icon           String?
  sortOrder      Int       @default(0)
  createdAt      DateTime  @default(now())
  products       Product[]
  // Relation explicite vers Professional pour permettre include({professional:true})
  // dans le service updateCategory/deleteCategory (ownership check).
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId])
  @@map("product_categories")
}

model Product {
  id             String           @id @default(uuid())
  professionalId String
  categoryId     String?
  name           Json
  description    Json?
  price          Float
  currency       String           @default("XOF")
  imageUrl       String?
  isAvailable    Boolean          @default(true)
  isMenu         Boolean          @default(false)
  stock          Int?
  variants       Json?
  options        Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  professional   Professional     @relation(fields: [professionalId], references: [id])
  category       ProductCategory? @relation(fields: [categoryId], references: [id])
  orderItems     OrderItem[]

  @@index([professionalId])
  @@index([categoryId])
  @@map("products")
}

// ─── ORDERS ───────────────────────────────────

model Order {
  id                  String         @id @default(uuid())
  clientId            String
  professionalId      String
  driverId            String?
  status              OrderStatus    @default(PENDING_PAYMENT)
  totalAmount         Float
  subtotal            Float
  deliveryFee         Float          @default(0)
  taxAmount           Float          @default(0)
  commissionAmount    Float          @default(0)
  currency            String
  deliveryAddress     String
  deliveryLat         Float
  deliveryLng         Float
  deliveryCity        String?
  deliveryCountry     String?
  paymentMethod       PaymentGateway
  paymentStatus       PaymentStatus  @default(PENDING)
  promoCode           String?
  promoDiscount       Float          @default(0)
  specialInstructions  String?
  scheduledDeliveryAt  DateTime?
  estimatedDeliveryMin Int?
  cancelledBy         String?
  cancelledReason     String?
  rejectedReason      String?
  weatherMultiplier   Float          @default(1)
  tipAmount           Float          @default(0)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  client              User           @relation("ClientOrders", fields: [clientId], references: [id])
  professional        Professional   @relation("ProfessionalOrders", fields: [professionalId], references: [id])
  driver              Driver?        @relation(fields: [driverId], references: [id])
  items               OrderItem[]
  payment             Payment?
  delivery            Delivery?
  review              Review?

  @@index([clientId])
  @@index([professionalId])
  @@index([driverId])
  @@index([status, createdAt])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  productId  String
  quantity   Int
  unitPrice  Float
  totalPrice Float
  options    Json?
  createdAt  DateTime @default(now())
  order      Order    @relation(fields: [orderId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// ─── PAYMENTS ─────────────────────────────────

model Payment {
  id           String         @id @default(uuid())
  orderId      String         @unique
  gateway      PaymentGateway
  amount       Float
  currency     String
  status       PaymentStatus  @default(PENDING)
  gatewayRef   String?
  gatewayData  Json?
  refundedAt   DateTime?
  refundAmount Float?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  order        Order          @relation(fields: [orderId], references: [id])

  @@map("payments")
}

// ─── DELIVERIES ───────────────────────────────

model Delivery {
  id            String         @id @default(uuid())
  orderId       String         @unique
  driverId      String
  status        DeliveryStatus @default(ASSIGNED)
  pickupTime    DateTime?
  deliveredTime DateTime?
  distanceKm    Float?
  driverLat     Float?
  driverLng     Float?
  confirmPhoto  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  order         Order          @relation(fields: [orderId], references: [id])
  driver        Driver         @relation(fields: [driverId], references: [id])

  @@index([driverId])
  @@map("deliveries")
}

// ─── REVIEWS ──────────────────────────────────

model Review {
  id                  String        @id @default(uuid())
  orderId             String        @unique
  reviewerId          String
  professionalId      String?
  driverId            String?
  professionalRating  Int?
  driverRating        Int?
  professionalComment String?
  driverComment       String?
  isModerated         Boolean       @default(false)
  professionalReply   String?
  createdAt           DateTime      @default(now())
  reviewer            User          @relation(fields: [reviewerId], references: [id])
  professional        Professional? @relation(fields: [professionalId], references: [id])
  driver              Driver?       @relation(fields: [driverId], references: [id])
  order               Order         @relation(fields: [orderId], references: [id])

  @@index([professionalId])
  @@index([driverId])
  @@map("reviews")
}

// ─── NOTIFICATIONS ────────────────────────────

model Notification {
  id        String              @id @default(uuid())
  userId    String
  type      NotificationType
  channel   NotificationChannel @default(PUSH)
  title     String
  body      String
  data      Json?
  read      Boolean             @default(false)
  createdAt DateTime            @default(now())
  user      User                @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, read])
  @@map("notifications")
}

// ─── MESSAGES ─────────────────────────────────

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())
  sender         User     @relation(fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}

// ─── PROMO CODES ──────────────────────────────

model PromoCode {
  id             String        @id @default(uuid())
  code           String        @unique
  type           String
  value          Float
  minOrder       Float         @default(0)
  maxUses        Int?
  usesCount      Int           @default(0)
  perUser        Boolean       @default(false)
  expiresAt      DateTime?
  countries      String[]
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  professionalId String?
  professional   Professional? @relation(fields: [professionalId], references: [id], onDelete: SetNull)

  @@index([professionalId])
  @@map("promo_codes")
}

model PromoCodeUsage {
  id          String   @id @default(uuid())
  promoCodeId String
  userId      String
  orderId     String
  usedAt      DateTime @default(now())

  @@index([promoCodeId])
  @@index([userId])
  @@map("promo_code_usages")
}

// ─── TRANSACTIONS ─────────────────────────────

model Transaction {
  id             String            @id @default(uuid())
  userId         String?
  professionalId String?
  driverId       String?
  orderId        String?
  type           TransactionType
  amount         Float
  currency       String
  status         TransactionStatus @default(PENDING)
  reference      String?
  description    String?
  createdAt      DateTime          @default(now())
  professional   Professional?     @relation(fields: [professionalId], references: [id])
  driver         Driver?           @relation(fields: [driverId], references: [id])

  @@index([professionalId])
  @@index([driverId])
  @@index([orderId])
  @@index([userId])
  @@map("transactions")
}

// ─── PLATFORM CONFIG ──────────────────────────

model PlatformConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("platform_config")
}

model DeliveryZone {
  id                String   @id @default(uuid())
  name              String
  country           String
  fromCity          String?
  toCity            String?
  baseFee           Float
  perKmFee          Float    @default(0)
  currency          String
  weatherMultiplier Float    @default(1)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  @@map("delivery_zones")
}

model Banner {
  id        String    @id @default(uuid())
  title     Json
  imageUrl  String
  linkUrl   String?
  countries String[]
  sortOrder Int       @default(0)
  startsAt  DateTime?
  endsAt    DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  @@map("banners")
}

model LegalPage {
  id        String   @id @default(uuid())
  type      String
  lang      Language
  title     String
  content   String   @db.Text
  version   String   @default("1.0")
  updatedAt DateTime @updatedAt

  @@unique([type, lang])
  @@map("legal_pages")
}

model ExchangeRate {
  id           String   @id @default(uuid())
  fromCurrency String
  toCurrency   String
  rate         Float
  updatedAt    DateTime @updatedAt

  @@unique([fromCurrency, toCurrency])
  @@map("exchange_rates")
}

// ─── WALLET & PARRAINAGE ──────────────────

model Wallet {
  id           String              @id @default(uuid())
  userId       String              @unique
  balance      Int                 @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  user         User                @relation(fields: [userId], references: [id])
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id          String       @id @default(uuid())
  walletId    String
  amount      Int
  type        WalletTxType
  description String?
  createdAt   DateTime     @default(now())
  wallet      Wallet       @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@map("wallet_transactions")
}

model Referral {
  id         String         @id @default(uuid())
  referrerId String
  refereeId  String         @unique
  status     ReferralStatus @default(PENDING)
  rewardedAt DateTime?
  createdAt  DateTime       @default(now())
  referrer   User           @relation("ReferrerReferrals", fields: [referrerId], references: [id])
  referee    User           @relation("RefereeReferral", fields: [refereeId], references: [id])

  @@index([referrerId])
  @@map("referrals")
}
